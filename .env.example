# GitHub authentication
# GitHub Actions provides GITHUB_TOKEN automatically. Use GH_TOKEN locally
# because custom GitHub secret names cannot start with GITHUB_.
GH_TOKEN=

# npm publishing
# Used by the release workflow to publish @santi020k/dep-beacon-core.
# Local release scripts pass this through as NODE_AUTH_TOKEN for npm.
# Generate at https://www.npmjs.com/settings/<user>/tokens
NPM_TOKEN=

# Turbo remote cache
# Used by CI to share Turbo artifacts across runs.
TURBO_TOKEN=
TURBO_TEAM=
TURBO_CONCURRENCY=10
TURBO_REMOTE_CACHE_TIMEOUT=30

# Docs site
# Used by the Astro docs app for canonical URLs and sitemap output.
# Use http://localhost:4321 when previewing docs locally.
DEP_BEACON_DOCS_URL=https://beacon.santi020k.com

# Cloudflare Pages deploy
# The deploy-docs workflow publishes apps/docs/dist to the dep-beacon-docs
# Pages project by default.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT_NAME=dep-beacon-docs

# VS Code extension publishing
# VSCE_PAT: Azure DevOps token with Marketplace Manage scope.
# OVSX_PAT: Open VSX token for the publisher namespace.
VSCE_PAT=
OVSX_PAT=

# Local extension debugging
# Valid values: local | production
DEP_BEACON_EXTENSION_ENV=local
DEP_BEACON_REGISTRY_URL=https://registry.npmjs.org
DEP_BEACON_LOG_FILE=.vscode/dep-beacon-extension-host.log
