{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "eslint.config.js",
    "packages/*/src/index.ts",
    "packages/vscode-dep-beacon/src/extension.ts",
    "packages/vscode-dep-beacon/scripts/*.cjs",
    "apps/docs/src/pages/**/*.astro"
  ],
  "project": [
    "apps/docs/src/**/*.{astro,ts}",
    "packages/*/src/**/*.ts",
    "packages/*/tests/**/*.ts",
    "packages/vscode-dep-beacon/scripts/*.cjs"
  ],
  "ignoreDependencies": [
    "@changesets/changelog-github",
    "@commitlint/cli",
    "@commitlint/config-conventional",
    "@vscode/vsce",
    "commitizen",
    "cz-conventional-changelog",
    "husky",
    "lint-staged",
    "ovsx",
    "wrangler"
  ]
}
