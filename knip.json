{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "scripts/*.mjs"
      ],
      "ignoreDependencies": [
        "tailwindcss"
      ],
      "project": [
        "scripts/**/*.mjs"
      ]
    },
    "apps/docs": {
      "entry": [
        "src/pages/**/*.astro"
      ],
      "ignoreDependencies": [
        "tailwindcss"
      ],
      "project": [
        "src/**/*.{astro,ts}"
      ]
    },
    "packages/dep-beacon-core": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts",
        "tests/**/*.ts"
      ]
    },
    "packages/vscode-dep-beacon": {
      "entry": [
        "scripts/*.cjs"
      ],
      "project": [
        "scripts/*.cjs",
        "src/**/*.ts",
        "tests/**/*.ts"
      ]
    }
  }
}
