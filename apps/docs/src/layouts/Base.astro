---
import '../styles/global.css'

import Footer from '../components/Footer.astro'
import Nav from '../components/Nav.astro'
import { SITE } from '../site.config'

interface Props {
  description?: string
  image?: string
  imageAlt?: string
  keywords?: readonly string[] | string
  title?: string
}

const {
  description = SITE.description,
  image = SITE.ogImage,
  imageAlt = `${SITE.name} social preview`,
  keywords = SITE.keywords,
  title = SITE.name,
} = Astro.props

const pageTitle = title === 'Dep Beacon' ? title : `${title} | Dep Beacon`
const canonicalUrl = new URL(Astro.url.pathname, SITE.url).toString()
const imageUrl = new URL(image, SITE.url).toString()
const keywordContent = typeof keywords === 'string' ? keywords : keywords.join(', ')

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    applicationCategory: 'DeveloperApplication',
    description: SITE.description,
    name: SITE.name,
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    operatingSystem: 'Windows, macOS, Linux',
    sameAs: [SITE.githubUrl, SITE.marketplaceUrl, SITE.openVsxUrl],
    url: SITE.url,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    description,
    image: imageUrl,
    isPartOf: {
      '@type': 'WebSite',
      name: SITE.name,
      url: SITE.url,
    },
    name: pageTitle,
    url: canonicalUrl,
  },
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywordContent} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#0b1115" />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:secure_url" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
