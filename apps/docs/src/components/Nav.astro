    <LogoMark class="brand-mark" />
    <span>{SITE.name}</span>
  </a>
  <nav class="top-nav" aria-label="Primary navigation">
    <a href="/docs">Docs</a>
    <a href="/docs/vscode-extension">Extension</a>
    <a href="/docs/pnpm-workspaces">pnpm</a>
    <a href={SITE.marketplaceUrl}>Marketplace</a>
    <a href={SITE.githubUrl}>GitHub</a>
  </nav>
</header>
